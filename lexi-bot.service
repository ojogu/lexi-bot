[Unit]
Description=Lexi Vocabulary Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/lexi-bot
EnvironmentFile=/opt/lexi-bot/.env
ExecStart=/opt/lexi-bot/venv/bin/python main.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
